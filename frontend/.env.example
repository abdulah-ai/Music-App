# Point this at your backend's LAN address, not localhost — a physical
# device or separate emulator can't reach your dev machine via 127.0.0.1.
# Android emulator can reach the host via 10.0.2.2.
EXPO_PUBLIC_API_BASE_URL=http://192.168.1.20:8095
# Set to true when the backend has SMA_REGISTRATION_INVITE_CODE configured.
EXPO_PUBLIC_REGISTRATION_INVITE_REQUIRED=false
