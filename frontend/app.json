{
  "expo": {
    "name": "Duskglen",
    "slug": "duskglen",
    "scheme": "duskglen",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#100B18",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.duskglen.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Duskglen listens briefly through the microphone to identify the song playing around you."
      }
    },
    "android": {
      "package": "com.duskglen.app",
      "adaptiveIcon": {
        "backgroundColor": "#100B18",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "name": "Duskglen",
      "shortName": "Duskglen",
      "themeColor": "#100B18",
      "backgroundColor": "#100B18"
    },
    "plugins": [
      [
        "expo-audio",
        {
          "microphonePermission": "Duskglen listens briefly through the microphone to identify the song playing around you."
        }
      ],
      "expo-asset",
      "expo-font",
      "expo-video"
    ]
  }
}
